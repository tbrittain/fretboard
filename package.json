    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
