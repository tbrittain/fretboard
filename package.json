    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.16",
    "playwright": "^1.57.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
